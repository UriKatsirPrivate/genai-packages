# Cloud Run deployment configuration for prompt-optimizer.
# Recorded from deployment Q&A on 2026-07-09. Edit values and re-run deploy.sh.

PROJECT_ID="landing-zone-demo-341118"
REGION="me-west1"                       # Cloud Run region (Tel Aviv)
SERVICE_NAME="prompt-optimizer"
AR_REPO="prompt-optimizer"              # Artifact Registry docker repo name
SERVICE_ACCOUNT="prompt-optimizer-run"  # runtime service account (granted roles/aiplatform.user)

# Gemini auth: Vertex AI via the service identity — no API key.
# GOOGLE_GENAI_USE_VERTEXAI=true is set on the service by deploy.sh.
VERTEX_LOCATION="global"                # Vertex endpoint for google-genai; 'global' has the widest Gemini model availability
GEMINI_MODEL="gemini-3.5-flash"

# Access: public web UI / API
ALLOW_UNAUTHENTICATED="true"

# Resources & scaling
MEMORY="512Mi"
CPU="1"
MIN_INSTANCES="0"
MAX_INSTANCES="3"
